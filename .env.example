# Optional fallback when OpenRouter free limits are hit
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free
LLM_PROVIDER=openrouter

# Speech-to-text (optional overrides)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ur
WHISPER_BEAM_SIZE=5
# Roman Urdu food-order hint — reduces Hindi mis-detection
# WHISPER_INITIAL_PROMPT=mujhe pizza chahiye, chicken karahi, biryani, Kasur.
STT_RECORD_SECONDS=5

# Text-to-speech (optional overrides)
TTS_MODEL=facebook/mms-tts-urd-script_latin
TTS_DEVICE=cpu
TTS_SAMPLE_RATE=16000
